# Optional. When omitted or left as MY_GEMINI_API_KEY, the FastAPI backend uses demo fallback responses.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Embedding model used by test_rag.py and the future RAG chat endpoint.
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"
GEMINI_EMBEDDING_BATCH_SIZE="100"

# Model used by /api/chat for tutor responses.
GEMINI_MODEL="gemini-flash-lite-latest"

# Source file indexed by the current RAG prototype.
RAG_SOURCE_FILE="data/textbook/chapter_1.txt"

# Local folders used by uploaded source ingestion.
UPLOAD_DIR="data/uploads"
PROCESSED_SOURCE_DIR="data/processed"

# Prototype ingestion limits. Keep these low on free-tier API keys.
MAX_UPLOAD_PAGES="35"
MAX_UPLOAD_CHUNKS="90"

# Minimum similarity score required before a source is passed into chat.
RAG_MIN_SCORE="0.55"

# Local frontend URL used for documentation and future callbacks.
APP_URL="http://localhost:5173"
